# Airtable
AIRTABLE_API_KEY=your_personal_access_token_here
AIRTABLE_BASE_ID=appXXXXXXXXXXXXXX
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXXX

# CORS — the domain allowed to call the API
ALLOWED_ORIGIN=https://www.homestudiolist.com

# Squarespace site URL — used to fetch listing images server-side (optional, defaults to https://www.homestudiolist.com)
SQUARESPACE_SITE_URL=https://www.homestudiolist.com
